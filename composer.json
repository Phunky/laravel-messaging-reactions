{
    "name": "phunky/laravel-messaging-reactions",
    "description": "Message reactions extension for phunky/laravel-messaging",
    "type": "library",
    "keywords": [
        "laravel",
        "laravel-messaging",
        "reactions",
        "chat"
    ],
    "homepage": "https://github.com/phunky/laravel-messaging-reactions",
    "support": {
        "issues": "https://github.com/phunky/laravel-messaging-reactions/issues",
        "source": "https://github.com/phunky/laravel-messaging-reactions"
    },
    "license": "MIT",
    "authors": [
        {
            "name": "Phunky",
            "email": "mark@phunky.co.uk",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.4",
        "phunky/laravel-messaging": "^0.0.1"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/boost": "^2.4",
        "laravel/pint": "^1.14",
        "nunomaduro/collision": "^8.8",
        "orchestra/testbench": "^11.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-arch": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Phunky\\LaravelMessagingReactions\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Phunky\\LaravelMessagingReactions\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "analyse": "vendor/bin/phpstan analyse --memory-limit=512M",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "branch-alias": {
            "dev-master": "0.0.x-dev"
        }
    },
    "prefer-stable": true
}
